---
interface Props {
	variant?: 'primary' | 'secondary';
	size?: 'sm' | 'md' | 'lg';
	href?: string;
	type?: 'button' | 'submit' | 'reset';
	class?: string;
}

const {
	variant = 'primary',
	size = 'md',
	href,
	type = 'button',
	class: className = '',
	...rest
} = Astro.props;

const baseClass =
	'inline-flex items-center justify-center whitespace-nowrap rounded-2xl font-bold uppercase no-underline transition duration-200 focus-visible:-translate-y-0.5 disabled:pointer-events-none disabled:opacity-50';

const variantClasses = {
	primary:
		'bg-primary text-primary-foreground shadow-[0_18px_36px_rgba(8,92,240,0.35)] hover:-translate-y-0.5 hover:opacity-95 hover:shadow-[0_24px_42px_rgba(8,92,240,0.4)] focus-visible:opacity-95 focus-visible:shadow-[0_24px_42px_rgba(8,92,240,0.4)]',
	secondary:
		'bg-secondary text-secondary-foreground shadow-[0_18px_36px_rgba(8,92,240,0.14)] hover:-translate-y-0.5 hover:opacity-95 hover:shadow-[0_24px_42px_rgba(8,92,240,0.2)] focus-visible:opacity-95 focus-visible:shadow-[0_24px_42px_rgba(8,92,240,0.2)]',
} as const;

const sizeClasses = {
	sm: 'px-4 py-[10px] text-[16px]',
	md: 'px-5 py-[15px] text-[18px]',
	lg: 'px-[22px] py-[18px] text-[20px]',
} as const;

const classes = [baseClass, variantClasses[variant], sizeClasses[size], className];
---

{href ? (
	<a class:list={classes} href={href} {...rest}>
		<slot />
	</a>
) : (
	<button class:list={classes} type={type} {...rest}>
		<slot />
	</button>
)}
